{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Nsight: Debug Heat3D (CUDA-GDB)",
            "type": "cuda-gdb",
            "request": "launch",
            "program": "${workspaceFolder}/build/heat3d",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,               // false = use integrated terminal (cleaner)
            "debuggerPath": "/usr/local/cuda/bin/cuda-gdb",  // optional but recommended if auto-detect fails
            "setupCommands": [
                {
                    "description": "Auto-stop on kernel launch (very useful for hitting kernel breakpoints)",
                    "text": "set cuda break_on_launch none",
                    "ignoreFailures": true
                },
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}